{
    "paths": {
        "logDirectory": "logs",
        "logFileName": "TsimCAT.log",
        "analysisDirectory": "analysis/session"
    },
    "links": {
        "tcp": {
            "port": 12345
        },
        "ads": {
            "ip": "127.0.0.1",
            "remoteNetId": "192.168.167.100.1.1",
            "localNetId": "192.168.167.100.1.20",
            "port": 851
        }
    },
    "simulation": {
        "localOnly": false,
        "stationModes": {
            "laserInternal": true,
            "robotInternal": true,
            "gantryInternal": true,
            "entryConveyorInternal": true,
            "exitConveyorInternal": true
        },
        "cellFlow": {
            "enabled": true,
            "autoStart": true,
            "inspectionRejectRate": 0.2
        }
    },
    "analyzer": {
        "enabled": false,
        "autoStart": true,
        "saveFrames": true,
        "saveTrace": true,
        "frameIntervalMs": 250,
        "traceIntervalMs": 100,
        "maxFrames": 240,
        "outputFolder": "analysis/session"
    },
    "adsVariables": {
        "robot": {
            "control": "MAIN.stRobotControl",
            "status": "MAIN.stRobotStatus"
        },
        "conveyors": {
            "entryRun": "MAIN.bEntryConveyorRun",
            "entrySensors": [
                "MAIN.bEntrySensor1",
                "MAIN.bEntrySensor2",
                "MAIN.bEntrySensor3"
            ],
            "exitRun": "MAIN.bExitConveyorRun",
            "exitSensors": [
                "MAIN.bExitSensor1",
                "MAIN.bExitSensor2"
            ],
            "transferRun": "MAIN.bTransferConveyorRun",
            "transferSensors": [
                "MAIN.bTransferSensor1",
                "MAIN.bTransferSensor2",
                "MAIN.bTransferSensor3"
            ]
        },
        "future": {
            "cameraTrigger": "MAIN.bCameraTrigger",
            "cameraResult": "MAIN.nCameraResult",
            "laserStart": "MAIN.bLaserStart",
            "laserDone": "MAIN.bLaserDone",
            "gantryPosX": "MAIN.fGantryPosX",
            "gantryPosZ": "MAIN.fGantryPosZ",
            "gantryGripCmd": "MAIN.bGantryGripCmd",
            "gantryGripFb": "MAIN.bGantryGripFb",
            "safetyDoorClosed": "MAIN.bSafetyDoorClosed",
            "safetyEStopOk": "MAIN.bEStopOk"
        }
    }
}